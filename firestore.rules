rules_version = '2';
// ─── Momentum PWA — Firestore Security Rules ─────────────────────────────────
//
// HOW TO DEPLOY THESE RULES:
//   Firebase Console → Firestore → Rules → paste this → Publish
//
// DATA STRUCTURE:
//   /users/{uid}      — user profile: email, name, plan, billing, role, joinedAt
//   /userdata/{uid}   — habit data:   habits[], logs{}
//
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own profile and habit data.
    // Admins can also read all user profiles (for the admin panel).
    match /users/{uid} {
      allow read:  if request.auth != null &&
                      (request.auth.uid == uid || isAdminUser());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /userdata/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Helper: check if the requesting user has admin role
    function isAdminUser() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
